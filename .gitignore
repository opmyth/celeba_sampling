# Result files (large tensors, regenerated by running the pipeline)
*.pt

# Environment / secrets
*.env
wandb/

# Logs (recreated by run_all.sh)
logs/

# Python bytecode
__pycache__/
*.pyc

# StyleGAN2 model checkpoint (download separately — see README).
# Track the directory but not the .pkl binary.
stylegan2_checkpoints/*.pkl
# Also ignore the .pkl that lives inside the code tree if left there
stylegan2-ada-pytorch/*.pkl

# CelebA dataset (download separately — see README)
data/

# Misc
*.json

*.md

.DS_Store

venv/

clf_checkpoints/
